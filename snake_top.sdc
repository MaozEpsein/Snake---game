// ============================================================================
//  Synopsys Design Constraints - Snake Game
//  Board : Sipeed Tang Nano 9K (Gowin GW1NR-LV9QN88PC6/I5)
//  LCD   : Sipeed 7" RGB 800x480 @ 60 Hz
//
//  Timing summary for 800x480 @ 60 Hz (RGB parallel):
//    HTOTAL = 800 + 40 (HFP) + 48 (HS) + 40 (HBP) =  928
//    VTOTAL = 480 + 13 (VFP) +  3 (VS) + 29 (VBP) =  525
//    Pixel clock = 928 * 525 * 60 Hz ~= 29.23 MHz  (30-33 MHz typical)
//  The rPLL in clock_divider.v is configured for 33 MHz pixel clock.
// ============================================================================

// --- Primary input clock: 27 MHz crystal on pin 52 --------------------------
create_clock -name clk_27 -period 37.037 -waveform {0 18.518} [get_ports {clk}]

// --- Pixel clock generated by the rPLL (~33 MHz, period 30.30 ns) -----------
create_generated_clock -name clk_pixel \
    -source [get_ports {clk}] \
    -master_clock clk_27 \
    -multiply_by 11 -divide_by 9 \
    [get_nets {clk_pixel}]

// Treat 27 MHz and pixel clock as asynchronous (PLL output crosses the reset
// domain only through the sys_reset synchronizer).
set_clock_groups -asynchronous \
    -group [get_clocks {clk_27}] \
    -group [get_clocks {clk_pixel}]

// --- Output timing for the LCD (driven by clk_pixel) ------------------------
//  Typical Sipeed 7" panel setup/hold: ~5 ns / ~5 ns at the panel pins.
set_output_delay -clock clk_pixel -max 5.0 \
    [get_ports {LCD_HSYNC LCD_VSYNC LCD_DEN LCD_R[*] LCD_G[*] LCD_B[*]}]
set_output_delay -clock clk_pixel -min -1.0 \
    [get_ports {LCD_HSYNC LCD_VSYNC LCD_DEN LCD_R[*] LCD_G[*] LCD_B[*]}]

// LCD_CLK is the forwarded pixel clock itself — exclude from data analysis.
set_false_path -to [get_ports {LCD_CLK}]

// --- Keypad (slow mechanical, debounced in logic) ---------------------------
set_false_path -from [get_ports {KEY_COL[*]}]
set_false_path -to   [get_ports {KEY_ROW[*]}]

// --- Reset button (asynchronous, synchronized inside RTL) -------------------
set_false_path -from [get_ports {reset_btn}]
